# ─────────────────────────────────────────────────────────────────────────────
# WALLET
# ─────────────────────────────────────────────────────────────────────────────
# Your Polygon wallet private key (0x-prefixed). Never commit this.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ─────────────────────────────────────────────────────────────────────────────
# POLYMARKET
# ─────────────────────────────────────────────────────────────────────────────
# Base URL for Polymarket CLOB API
POLYMARKET_API_BASE=https://clob.polymarket.com

# Your Polymarket L2 API key (generated from the Polymarket dashboard)
POLYMARKET_API_KEY=your_l2_api_key

# Your Polymarket proxy wallet address (the contract wallet Polymarket uses)
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_WALLET

# ─────────────────────────────────────────────────────────────────────────────
# CHAIN (Polygon Mainnet)
# ─────────────────────────────────────────────────────────────────────────────
# Polygon RPC endpoint — use a dedicated node (Alchemy/Infura) for reliability
RPC_URL=https://polygon-rpc.com

# Polygon mainnet chain ID
CHAIN_ID=137

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — used by dashboard browser JS (public, safe to expose)
SUPABASE_ANON_KEY=your_anon_key

# Supabase service role key — used by the bot server only. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
# Redis connection string for distributed locking
REDIS_URL=redis://localhost:6379

# How long a distributed lock is held before auto-expiry (ms). Default 30s.
LOCK_TTL_MS=30000

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token

# Telegram chat ID to send alerts to (your user ID or a group ID)
TELEGRAM_CHAT_ID=your_chat_id

# ─────────────────────────────────────────────────────────────────────────────
# DASHBOARD + AUTH
# ─────────────────────────────────────────────────────────────────────────────
# Express server port. Access via SSH tunnel on VPS — do NOT expose publicly.
DASHBOARD_PORT=3003

# The email address that has admin privileges (full bot controls).
# All other registered users are read-only subscribers.
ADMIN_EMAIL=your@email.com

# Your public URL (with https://) — required for Telegram Login Widget to work.
# Use your domain name or IP. No trailing slash.
APP_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
# Winston log level: error | warn | info | debug
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
# Set to 'production' on VPS. Controls log format (JSON vs coloured console).
NODE_ENV=development
